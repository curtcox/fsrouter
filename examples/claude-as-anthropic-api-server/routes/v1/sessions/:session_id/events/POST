#!/usr/bin/env python3
"""
POST /v1/sessions/:session_id/events — Send events to a session.
Accepts user messages and processes them via the claude CLI.
Returns the agent's response events.
"""
import sys, os, json, time
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "..", "lib"))
from claude_bridge import read_request_body, respond, error_response, call_claude, generate_message_id
import store

def main():
    session_id = os.environ.get("PARAM_SESSION_ID", "")

    session = store.get("session", session_id)
    if not session:
        error_response("not_found_error", f"Session '{session_id}' not found", 400)

    try:
        body = read_request_body()
    except Exception as e:
        error_response("invalid_request_error", f"Invalid JSON: {e}")

    events = body.get("events", [])
    if not events:
        error_response("invalid_request_error", "events: field required")

    # Extract user message text from events
    user_messages = []
    for event in events:
        event_type = event.get("type", "")
        if event_type == "user.message":
            content = event.get("content", [])
            for block in content:
                if block.get("type") == "text":
                    user_messages.append(block.get("text", ""))

    if not user_messages:
        error_response("invalid_request_error", "No user.message events with text content found")

    prompt_text = "\n".join(user_messages)

    # Get agent config from session
    agent = session.get("agent", {})
    model = agent.get("model", {})
    model_id = model.get("id", "claude-sonnet-4-6") if isinstance(model, dict) else model
    system = agent.get("system", "")

    # Build messages array for claude CLI
    messages = [{"role": "user", "content": prompt_text}]

    # Call claude CLI
    result = call_claude(
        messages=messages,
        model=model_id,
        system=system if system else None,
        timeout=300,
    )

    # Update session status
    store.update("session", session_id, {"status": "idle"})

    # Build response events
    response_events = []

    if "error" in result:
        response_events.append({
            "type": "error",
            "error": {"type": "api_error", "message": result["error"]},
        })
    else:
        text = result.get("result", "")
        msg_id = generate_message_id()

        response_events.append({
            "type": "agent.message",
            "id": msg_id,
            "content": [{"type": "text", "text": text}],
        })
        response_events.append({
            "type": "session.status_idle",
        })

        # Update usage
        usage = result.get("usage", {})
        store.update("session", session_id, {
            "usage": {
                "input_tokens": session.get("usage", {}).get("input_tokens", 0) + usage.get("input_tokens", 0),
                "output_tokens": session.get("usage", {}).get("output_tokens", 0) + usage.get("output_tokens", 0),
                "cache_read_input_tokens": 0,
                "cache_creation": {"ephemeral_1h_input_tokens": 0, "ephemeral_5m_input_tokens": 0},
            }
        })

    respond({"events": response_events})

if __name__ == "__main__":
    main()
