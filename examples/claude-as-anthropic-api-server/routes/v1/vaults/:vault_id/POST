#!/usr/bin/env python3
"""POST /v1/vaults/:vault_id — Update Vault"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "lib"))
from claude_bridge import read_request_body, respond, error_response
import store

def main():
    vault_id = os.environ.get("PARAM_VAULT_ID", "")
    try:
        body = read_request_body()
    except Exception as e:
        error_response("invalid_request_error", f"Invalid JSON: {e}")

    vault = store.get("vault", vault_id)
    if not vault:
        error_response("not_found_error", f"Vault '{vault_id}' not found", 400)

    updates = {}
    for field in ("display_name", "metadata"):
        if field in body:
            updates[field] = body[field]

    vault = store.update("vault", vault_id, updates)
    respond(vault)

if __name__ == "__main__":
    main()
