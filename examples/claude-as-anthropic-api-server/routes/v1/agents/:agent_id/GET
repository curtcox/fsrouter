#!/usr/bin/env python3
"""GET /v1/agents/:agent_id — Retrieve Agent"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "lib"))
from claude_bridge import respond, error_response
import store

def main():
    agent_id = os.environ.get("PARAM_AGENT_ID", "")
    agent = store.get("agent", agent_id)
    if not agent:
        error_response("not_found_error", f"Agent '{agent_id}' not found", 400)
    respond(agent)

if __name__ == "__main__":
    main()
