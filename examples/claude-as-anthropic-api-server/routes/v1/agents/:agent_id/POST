#!/usr/bin/env python3
"""POST /v1/agents/:agent_id — Update Agent"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "lib"))
from claude_bridge import read_request_body, respond, error_response
import store

def main():
    agent_id = os.environ.get("PARAM_AGENT_ID", "")
    try:
        body = read_request_body()
    except Exception as e:
        error_response("invalid_request_error", f"Invalid JSON: {e}")

    agent = store.get("agent", agent_id)
    if not agent:
        error_response("not_found_error", f"Agent '{agent_id}' not found", 400)

    updates = {}
    for field in ("name", "description", "model", "system", "tools", "mcp_servers", "skills", "metadata"):
        if field in body:
            updates[field] = body[field]

    if updates:
        # Bump version
        updates["version"] = agent.get("version", 1) + 1
        if "model" in updates and isinstance(updates["model"], str):
            updates["model"] = {"id": updates["model"], "speed": "standard"}

    agent = store.update("agent", agent_id, updates)
    respond(agent)

if __name__ == "__main__":
    main()
