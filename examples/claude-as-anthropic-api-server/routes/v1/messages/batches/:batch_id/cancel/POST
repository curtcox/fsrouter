#!/usr/bin/env python3
"""
POST /v1/messages/batches/:batch_id/cancel — Cancel a batch.
"""
import sys
import os
import json
import time

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "..", "..", "lib"))
from claude_bridge import respond, error_response

BATCH_DIR = os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "..", "..", "data", "batches")


def main():
    batch_id = os.environ.get("PARAM_BATCH_ID", "")
    path = os.path.join(BATCH_DIR, f"{batch_id}.json")

    if not os.path.isfile(path):
        error_response("not_found_error", f"Batch '{batch_id}' not found", 400)

    with open(path) as f:
        batch = json.load(f)

    batch["processing_status"] = "canceled"
    batch["ended_at"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())

    # Update canceled count
    remaining = batch["request_counts"]["processing"]
    batch["request_counts"]["canceled"] = remaining
    batch["request_counts"]["processing"] = 0

    with open(path, "w") as f:
        json.dump(batch, f, indent=2)

    batch.pop("requests", None)
    respond(batch)


if __name__ == "__main__":
    main()
