#!/usr/bin/env python3
"""GET /v1/files/:file_id — Retrieve File metadata"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "..", "lib"))
from claude_bridge import respond, error_response
import store

def main():
    file_id = os.environ.get("PARAM_FILE_ID", "")
    f = store.get("file", file_id)
    if not f:
        error_response("not_found_error", f"File '{file_id}' not found", 400)
    respond(f)

if __name__ == "__main__":
    main()
