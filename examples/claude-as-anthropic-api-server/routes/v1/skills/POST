#!/usr/bin/env python3
"""POST /v1/skills — Create Skill"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "lib"))
from claude_bridge import read_request_body, respond, error_response
import store

def main():
    try:
        body = read_request_body()
    except Exception as e:
        error_response("invalid_request_error", f"Invalid JSON: {e}")

    skill = store.create("skill", "skill", {
        "display_title": body.get("display_title", "Untitled Skill"),
        "source": "custom",
        "latest_version": "1",
        "content": body.get("content", ""),
        "description": body.get("description", ""),
    })
    respond(skill)

if __name__ == "__main__":
    main()
