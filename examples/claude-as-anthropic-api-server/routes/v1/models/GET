#!/usr/bin/env python3
"""
GET /v1/models — List available models.
Returns models compatible with the Anthropic Models API format.
"""
import sys
import os

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "..", "..", "lib"))
from claude_bridge import respond, MODEL_CATALOG


def main():
    # Parse query params from env
    limit = int(os.environ.get("QUERY_LIMIT", "20"))
    after_id = os.environ.get("QUERY_AFTER_ID", "")
    before_id = os.environ.get("QUERY_BEFORE_ID", "")

    models = list(MODEL_CATALOG)

    # Handle pagination
    if after_id:
        found = False
        filtered = []
        for m in models:
            if found:
                filtered.append(m)
            if m["id"] == after_id:
                found = True
        models = filtered

    if before_id:
        filtered = []
        for m in models:
            if m["id"] == before_id:
                break
            filtered.append(m)
        models = filtered

    models = models[:limit]
    has_more = len(MODEL_CATALOG) > limit

    respond({
        "data": models,
        "has_more": has_more,
        "first_id": models[0]["id"] if models else None,
        "last_id": models[-1]["id"] if models else None,
    })


if __name__ == "__main__":
    main()
