#!/usr/bin/env python3
from pathlib import Path
import sys

current = Path(__file__).resolve()
for parent in current.parents:
    candidate = parent / "lib" / "ai_change_app.py"
    if candidate.exists():
        sys.path.insert(0, str(parent / "lib"))
        break

from ai_change_app import handle_file_view, render_error_page


if __name__ == "__main__":
    try:
        handle_file_view()
    except Exception as err:  # pragma: no cover - CGI surface
        render_error_page(err)
